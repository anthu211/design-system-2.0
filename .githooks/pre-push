#!/bin/bash
# pre-push hook — auto-increments patch version in index.html on every push
# Format: vMAJOR.MINOR.PATCH  →  vMAJOR.MINOR.(PATCH+1)

REPO_ROOT="$(git rev-parse --show-toplevel)"
FILE="$REPO_ROOT/index.html"

# Read current version
CURRENT=$(grep -o 'v[0-9]\+\.[0-9]\+\.[0-9]\+' "$FILE" | head -1)
if [ -z "$CURRENT" ]; then
  echo "[pre-push] No version tag found in index.html — skipping bump."
  exit 0
fi

# Parse components
MAJOR=$(echo "$CURRENT" | sed 's/v//' | cut -d. -f1)
MINOR=$(echo "$CURRENT" | sed 's/v//' | cut -d. -f2)
PATCH=$(echo "$CURRENT" | sed 's/v//' | cut -d. -f3)

# Increment patch
NEW_PATCH=$((PATCH + 1))
NEW_VERSION="v${MAJOR}.${MINOR}.${NEW_PATCH}"

# Update index.html (macOS-compatible sed)
sed -i '' "s/${CURRENT}/${NEW_VERSION}/g" "$FILE"

echo "[pre-push] Version bumped: ${CURRENT} → ${NEW_VERSION}"

# Commit the bump, then push it immediately so it's included in this push
BRANCH=$(git -C "$REPO_ROOT" symbolic-ref --short HEAD)
git -C "$REPO_ROOT" add "$FILE"
git -C "$REPO_ROOT" commit -m "chore: bump version to ${NEW_VERSION}"
git -C "$REPO_ROOT" push --no-verify origin "HEAD:${BRANCH}"

# The outer push will now find nothing new to send (already done above)
exit 0
